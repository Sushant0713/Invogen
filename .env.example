# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:5000/api/v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/invogen

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_REMEMBER_EXPIRES_IN=30d

# Cashfree — get sandbox keys from https://merchant.cashfree.com/merchants/pg/developers/api-keys
CASHFREE_APP_ID=your_app_id
CASHFREE_SECRET_KEY=your_secret_key
CASHFREE_ENV=sandbox
# Webhook secret from Cashfree Dashboard → Webhooks (optional for local dev)
CASHFREE_WEBHOOK_SECRET=

# SMTP — port 465 requires SMTP_SECURE=true; port 587 uses STARTTLS (SMTP_SECURE=false)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Invogen <noreply@invogen.app>

# Super Admin Seed
SUPER_ADMIN_EMAIL=admin@invogen.app
SUPER_ADMIN_PASSWORD=Admin@123456

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:5173 (and your production URL)
GOOGLE_CLIENT_ID=

# Client
VITE_API_URL=http://localhost:5000/api/v1

# ── Docker production (on the VPS; keep secrets only in the server .env) ──
# NODE_ENV=production
# PORT=5000
# CLIENT_URL=https://your-domain.com
# API_PUBLIC_URL=https://your-domain.com/api/v1
# MONGODB_URI=mongodb+srv://...
# VITE_API_URL=/api/v1
# VITE_GOOGLE_CLIENT_ID= (or reuse GOOGLE_CLIENT_ID for the client image build)
